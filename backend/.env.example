APP_NAME=SSHome IoT Control System
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/iot_control
DATABASE_ECHO=false
DATABASE_AUTO_INIT=false
AUTH_MODE=jwt
AUTH_JWT_SECRET_KEY=super-secret-key
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_OWNER_ID_CLAIM=owner_id
AUTH_JWT_SUBJECT_CLAIM=sub
AUTH_JWT_ROLES_CLAIM=roles
AUTH_JWT_ROLE_CLAIM=role
AUTH_JWT_TOKEN_TYPE_CLAIM=type
AUTH_JWT_ACCESS_TOKEN_TYPE=access
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_INTROSPECTION_URL=
AUTH_INTROSPECTION_TIMEOUT_SECONDS=5
JWT_SECRET_KEY=super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOW_ORIGINS=http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|192\\.168\\.\\d+\\.\\d+|10\\.\\d+\\.\\d+\\.\\d+)(:\\d+)?$
